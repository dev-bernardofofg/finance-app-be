{
  "swagger": "2.0",
  "info": {
    "title": "Finance App API",
    "version": "1.0.0",
    "description": "API do Finance App that allows you to manage your finances"
  },
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Enter 'Bearer' seguido do seu token JWT. Exemplo: Bearer <token>"
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "User",
      "description": "User account, authentication and balance"
    },
    {
      "name": "Transaction",
      "description": "Financial transactions of the authenticated user"
    }
  ],
  "paths": {
    "/users": {
      "post": {
        "summary": "Register a new user",
        "description": "Creates a user account and returns the user with its access tokens.",
        "operationId": "createUser",
        "tags": ["User"],
        "security": [],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CreateUserParams"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User created successfully",
            "schema": {
              "$ref": "#/definitions/UserWithToken"
            }
          },
          "400": {
            "description": "Invalid request body",
            "schema": {
              "$ref": "#/definitions/InvalidRequestBodyError"
            }
          },
          "409": {
            "description": "Email already in use",
            "schema": {
              "$ref": "#/definitions/EmailAlreadyInUseError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      }
    },
    "/users/login": {
      "post": {
        "summary": "Authenticate a user",
        "description": "Validates credentials and returns the user with its access tokens.",
        "operationId": "loginUser",
        "tags": ["User"],
        "security": [],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LoginUserParams"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User authenticated successfully",
            "schema": {
              "$ref": "#/definitions/UserWithToken"
            }
          },
          "400": {
            "description": "Invalid request body",
            "schema": {
              "$ref": "#/definitions/InvalidRequestBodyError"
            }
          },
          "401": {
            "description": "Invalid credentials",
            "schema": {
              "$ref": "#/definitions/UnauthorizedError"
            }
          },
          "404": {
            "description": "Email not found",
            "schema": {
              "$ref": "#/definitions/EmailUserNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      }
    },
    "/users/refresh-token": {
      "post": {
        "summary": "Refresh access tokens",
        "description": "Exchanges a valid refresh token for a new pair of access tokens.",
        "operationId": "refreshToken",
        "tags": ["User"],
        "security": [],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RefreshTokenParams"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tokens refreshed successfully",
            "schema": {
              "$ref": "#/definitions/AuthTokens"
            }
          },
          "400": {
            "description": "Invalid request body",
            "schema": {
              "$ref": "#/definitions/InvalidRequestBodyError"
            }
          },
          "401": {
            "description": "Invalid or expired refresh token",
            "schema": {
              "$ref": "#/definitions/UnauthorizedError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      }
    },
    "/users/me": {
      "get": {
        "summary": "Get the authenticated user",
        "operationId": "getMe",
        "tags": ["User"],
        "responses": {
          "200": {
            "description": "User found successfully",
            "schema": {
              "$ref": "#/definitions/User"
            }
          },
          "404": {
            "description": "User not found",
            "schema": {
              "$ref": "#/definitions/UserNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      },
      "patch": {
        "summary": "Update the authenticated user",
        "operationId": "updateMe",
        "tags": ["User"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UpdateUserParams"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User updated successfully",
            "schema": {
              "$ref": "#/definitions/UpdateUserResponse"
            }
          },
          "400": {
            "description": "Invalid request body",
            "schema": {
              "$ref": "#/definitions/InvalidRequestBodyError"
            }
          },
          "404": {
            "description": "User not found",
            "schema": {
              "$ref": "#/definitions/UserNotFoundError"
            }
          },
          "409": {
            "description": "Email already in use",
            "schema": {
              "$ref": "#/definitions/EmailAlreadyInUseError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      },
      "delete": {
        "summary": "Delete the authenticated user",
        "operationId": "deleteMe",
        "tags": ["User"],
        "responses": {
          "200": {
            "description": "User deleted successfully",
            "schema": {
              "$ref": "#/definitions/User"
            }
          },
          "404": {
            "description": "User not found",
            "schema": {
              "$ref": "#/definitions/UserNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      }
    },
    "/users/me/balance": {
      "get": {
        "summary": "Get the authenticated user balance",
        "description": "Returns income, expense and investment totals plus their percentages, optionally filtered by date range.",
        "operationId": "getMyBalance",
        "tags": ["User"],
        "parameters": [
          {
            "name": "from_date",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date",
            "description": "Start date of the balance period (format: YYYY-MM-DD)"
          },
          {
            "name": "to_date",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date",
            "description": "End date of the balance period (format: YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "User balance found successfully",
            "schema": {
              "$ref": "#/definitions/UserBalance"
            }
          },
          "404": {
            "description": "User not found",
            "schema": {
              "$ref": "#/definitions/UserNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      }
    },
    "/transactions": {
      "post": {
        "summary": "Create a transaction",
        "operationId": "createTransaction",
        "tags": ["Transaction"],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CreateTransactionParams"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Transaction created successfully",
            "schema": {
              "$ref": "#/definitions/Transaction"
            }
          },
          "400": {
            "description": "Invalid request body",
            "schema": {
              "$ref": "#/definitions/InvalidRequestBodyError"
            }
          },
          "404": {
            "description": "User not found",
            "schema": {
              "$ref": "#/definitions/UserNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      },
      "get": {
        "summary": "List the authenticated user transactions",
        "description": "Returns the transactions of the authenticated user, optionally filtered by date range.",
        "operationId": "getTransactions",
        "tags": ["Transaction"],
        "parameters": [
          {
            "name": "from_date",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date",
            "description": "Start date of the transactions to get (format: YYYY-MM-DD)"
          },
          {
            "name": "to_date",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date",
            "description": "End date of the transactions to get (format: YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Transactions found successfully",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Transaction"
              }
            }
          },
          "404": {
            "description": "User not found",
            "schema": {
              "$ref": "#/definitions/UserNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      }
    },
    "/transactions/{id}": {
      "get": {
        "summary": "Get a transaction by ID",
        "operationId": "getTransactionById",
        "tags": ["Transaction"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string",
            "format": "uuid",
            "description": "ID of the transaction to get"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction found successfully",
            "schema": {
              "$ref": "#/definitions/Transaction"
            }
          },
          "404": {
            "description": "Transaction not found",
            "schema": {
              "$ref": "#/definitions/TransactionNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      },
      "put": {
        "summary": "Update a transaction by ID",
        "operationId": "updateTransaction",
        "tags": ["Transaction"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string",
            "format": "uuid",
            "description": "ID of the transaction to update"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UpdateTransactionParams"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction updated successfully",
            "schema": {
              "$ref": "#/definitions/Transaction"
            }
          },
          "400": {
            "description": "Invalid request body",
            "schema": {
              "$ref": "#/definitions/InvalidRequestBodyError"
            }
          },
          "404": {
            "description": "Transaction not found",
            "schema": {
              "$ref": "#/definitions/TransactionNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a transaction by ID",
        "operationId": "deleteTransaction",
        "tags": ["Transaction"],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "string",
            "format": "uuid",
            "description": "ID of the transaction to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction deleted successfully",
            "schema": {
              "$ref": "#/definitions/Transaction"
            }
          },
          "404": {
            "description": "Transaction not found",
            "schema": {
              "$ref": "#/definitions/TransactionNotFoundError"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/InternalServerError"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "User": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "first_name": {
          "type": "string",
          "example": "John"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        }
      },
      "required": ["id", "first_name", "last_name", "email"]
    },
    "Transaction": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "name": {
          "type": "string",
          "example": "Salary"
        },
        "type": {
          "type": "string",
          "enum": ["INCOME", "EXPENSE", "INVESTMENT"]
        },
        "amount": {
          "type": "number",
          "example": 1000
        }
      },
      "required": ["id", "name", "type", "amount"]
    },
    "AuthTokens": {
      "type": "object",
      "properties": {
        "access_token": {
          "type": "string",
          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
        },
        "refresh_token": {
          "type": "string",
          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
        }
      },
      "required": ["access_token", "refresh_token"]
    },
    "UserWithToken": {
      "allOf": [
        {
          "$ref": "#/definitions/User"
        },
        {
          "type": "object",
          "properties": {
            "tokens": {
              "$ref": "#/definitions/AuthTokens"
            }
          },
          "required": ["tokens"]
        }
      ]
    },
    "CreateUserParams": {
      "type": "object",
      "properties": {
        "first_name": {
          "type": "string",
          "example": "John"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        },
        "password": {
          "type": "string",
          "example": "password123"
        }
      },
      "required": ["first_name", "last_name", "email", "password"]
    },
    "LoginUserParams": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        },
        "password": {
          "type": "string",
          "example": "password123"
        }
      },
      "required": ["email", "password"]
    },
    "RefreshTokenParams": {
      "type": "object",
      "properties": {
        "refreshToken": {
          "type": "string",
          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
        }
      },
      "required": ["refreshToken"]
    },
    "UpdateUserParams": {
      "type": "object",
      "properties": {
        "first_name": {
          "type": "string",
          "example": "John"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        }
      }
    },
    "UpdateUserResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "first_name": {
          "type": "string",
          "example": "John"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        }
      },
      "required": ["id", "first_name", "last_name", "email"]
    },
    "UserBalance": {
      "type": "object",
      "properties": {
        "total_income": {
          "type": "number",
          "example": 1000
        },
        "total_expenses": {
          "type": "number",
          "example": 1000
        },
        "total_investments": {
          "type": "number",
          "example": 1000
        },
        "balance": {
          "type": "number",
          "example": 1000
        },
        "earning_percentage": {
          "type": "number",
          "example": 100
        },
        "investment_percentage": {
          "type": "number",
          "example": 100
        },
        "expenses_percentage": {
          "type": "number",
          "example": 100
        }
      },
      "required": [
        "total_income",
        "total_expenses",
        "total_investments",
        "balance",
        "earning_percentage",
        "investment_percentage",
        "expenses_percentage"
      ]
    },
    "CreateTransactionParams": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Salary"
        },
        "type": {
          "type": "string",
          "enum": ["INCOME", "EXPENSE", "INVESTMENT"]
        },
        "amount": {
          "type": "number",
          "example": 1000
        }
      },
      "required": ["name", "type", "amount"]
    },
    "UpdateTransactionParams": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Salary"
        },
        "type": {
          "type": "string",
          "enum": ["INCOME", "EXPENSE", "INVESTMENT"]
        },
        "amount": {
          "type": "number",
          "example": 1000
        }
      }
    },
    "InvalidRequestBodyError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Campos inválidos: {fields}"
        }
      }
    },
    "UnauthorizedError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Não autorizado"
        }
      }
    },
    "UserNotFoundError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "User com ID {id} não encontrado."
        }
      }
    },
    "EmailUserNotFoundError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Email {email} não encontrado."
        }
      }
    },
    "EmailAlreadyInUseError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "O email {email} já está em uso."
        }
      }
    },
    "TransactionNotFoundError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Transação com ID {transactionId} não encontrada."
        }
      }
    },
    "InternalServerError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Erro ao {action}"
        }
      }
    }
  }
}
