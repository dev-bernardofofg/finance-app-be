  },
  "definitions": {
    "User": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "first_name": {
          "type": "string",
          "example": "John"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        },
        "password": {
          "type": "string",
          "example": "password123"
        }
      },
      "required": ["id", "first_name", "last_name", "email"]
    },
    "UserBalance": {
      "type": "object",
      "properties": {
        "total_income": {
          "type": "number",
          "example": 1000
        },
        "total_expenses": {
          "type": "number",
          "example": 1000
        },
        "total_investments": {
          "type": "number",
          "example": 1000
        },
        "balance": {
          "type": "number",
          "example": 1000
        }
      }
    },
    "Transaction": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "user_id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "name": {
          "type": "string",
          "example": "John Doe"
        },
        "type": {
          "type": "string",
          "enum": ["INCOME", "EXPENSE", "INVESTMENT"]
        },
        "amount": {
          "type": "number",
          "example": 1000
        }
      },
      "required": ["id", "user_id", "name", "type", "amount"]
    },
    "CreateTransactionParams": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "name": {
          "type": "string",
          "example": "John Doe"
        },
        "type": {
          "type": "string",
          "enum": ["INCOME", "EXPENSE", "INVESTMENT"]
        },
        "amount": {
          "type": "number",
          "example": 1000
        }
      },
      "required": ["user_id", "name", "type", "amount"]
    },
    "GetUserByEmailParams": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        }
      },
      "required": ["email"]
    },
    "GetUserIdParams": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        }
      }
    },
    "EmailUserNotFoundError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Email {email} não encontrado."
        }
      }
    },
    "TransactionNotFoundError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Transação com ID {transactionId} não encontrada."
        }
      }
    },
    "UpdateUserParams": {
      "type": "object",
      "properties": {
        "first_name": {
          "type": "string",
          "example": "John"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        }
      }
    },
    "UpdateUserResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "first_name": {
          "type": "string",
          "example": "John"
        },
        "last_name": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "john.doe@example.com"
        }
      },
      "required": ["id", "first_name", "last_name", "email"]
    },
    "UpdateTransactionParams": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "John Doe"
        },
        "type": {
          "type": "string",
          "enum": ["INCOME", "EXPENSE", "INVESTMENT"]
        },
        "amount": {
          "type": "number",
          "example": 1000
        }
      }
    },
    "UserNotFoundError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "User com ID {id} não encontrado."
        }
      }
    },
    "EmailAlreadyInUseError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "O email {email} já está em uso."
        }
      }
    },
    "InternalServerError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Erro ao {action}"
        }
      }
    },
    "InvalidRequestBodyError": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "example": "Campos inválidos: {fields}"
        }
      }
    }
  }
}
