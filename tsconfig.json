{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },
    "types": ["jest"],
    "typeRoots": ["./node_modules/@types", "./src/@types"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src", "generated"],
  "exclude": ["node_modules", "dist"]
}
